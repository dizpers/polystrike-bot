# Polystrike API Configuration
POLYSTRIKE_API_KEY=ps_pro_your_key_here
POLYSTRIKE_API_URL=https://polystrike.xyz/api/v1

# Polymarket Wallet Configuration
WALLET_PRIVATE_KEY=0x...
WALLET_ADDRESS=0x...
CHAIN_ID=137

# Trading Parameters
BANKROLL=100.0
MAX_POSITION_SIZE=30.0
MIN_EDGE=0.05
STOP_LOSS_PCT=-0.30
MAX_PORTFOLIO_EXPOSURE=0.80

# Risk Management
REQUIRE_APPROVAL=false
DRY_RUN=false
MIN_CONFIDENCE=MEDIUM

# Polling Configuration
POLL_INTERVAL_SECONDS=300

# Telegram Alerts (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Logging
LOG_LEVEL=INFO
LOG_FILE=trades.log
